# Copier vers .env et remplir. .env est gitignoré.

# Google Places API (New) — console.cloud.google.com, activer "Places API (New)".
# ~200$/mois de crédit gratuit Google Maps Platform = largement assez pour nos volumes.
GOOGLE_PLACES_API_KEY=

# Hunter.io — hunter.io/api, free tier: 25 recherches/mois.
HUNTER_API_KEY=

# Apify — apify.com → Settings → API & Integrations → token. Free tier: 5$/mois crédit.
# Utilisé pour scraper Meta Ad Library (lane A).
APIFY_TOKEN=
