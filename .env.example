# Copy to .env and fill in. .env is gitignored.

# Google Places API (New) — console.cloud.google.com, enable "Places API (New)".
# ~$200/month free Google Maps Platform credit = plenty for our volumes.
GOOGLE_PLACES_API_KEY=

# Hunter.io — hunter.io/api, free tier: 25 searches/month.
HUNTER_API_KEY=

# Apify — apify.com → Settings → API & Integrations → token. Free tier: $5/month credit.
# Used to scrape the Meta Ad Library (lane A).
APIFY_TOKEN=
